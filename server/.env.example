ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
PORT=3001
NODE_ENV=development

# Token d'authentification de l'API (OBLIGATOIRE en production).
# Le client le saisit une fois ; il est envoyé dans l'en-tête x-app-token.
# Générer avec : openssl rand -hex 24
APP_AUTH_TOKEN=

# Clé de chiffrement AES-256 pour les secrets en base (OBLIGATOIRE en production)
# Générer avec : openssl rand -hex 32
ENCRYPTION_KEY=

# Plafond de coût IA quotidien en USD (0 = désactivé). Défaut : 5
AI_DAILY_USD_CAP=5

# Légifrance — API PISTE (https://beta.piste.gouv.fr)
PISTE_OAUTH_CLIENT_ID=
PISTE_OAUTH_CLIENT_SECRET=

# Email alertes synchro automatique (optionnel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

# Hôte public de l'app (pour CORS en production), ex : 179.237.66.21
APP_HOST=

# PWA push notifications (générer avec : npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Sujet VAPID (mailto: ou https:), ex : mailto:contact@votre-domaine.fr
VAPID_SUBJECT=
